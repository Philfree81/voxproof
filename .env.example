# ─── Domaines (Docker / production) ────────────────────
APP_DOMAIN="app.client.com"          # frontend + api.app.client.com + audio.app.client.com
BLOG_DOMAIN="blog.client.com"        # Ghost (si GHOST_ENABLED=true)
GHOST_ENABLED="false"                # true = démarre Ghost + nginx ghost
LETSENCRYPT_EMAIL="admin@client.com" # Pour les certificats SSL

# ─── PostgreSQL (Docker) ─────────────────────────────────
POSTGRES_USER="voxproof"
POSTGRES_PASSWORD="change-me-strong-password"
POSTGRES_DB="voxproof"

# ─── Database ───────────────────────────────────────────
# Dev local: postgresql://voxproof:password@localhost:5432/voxproof
# Docker   : automatiquement remplacé par docker-compose.yml
DATABASE_URL="postgresql://voxproof:password@localhost:5432/voxproof"

# ─── JWT ────────────────────────────────────────────────
JWT_SECRET="change-me-to-a-long-random-secret"
JWT_EXPIRES_IN="7d"

# ─── Pinata (IPFS) ──────────────────────────────────────
PINATA_API_KEY=""
PINATA_SECRET_API_KEY=""
PINATA_JWT=""

# ─── Avalanche (mainnet C-Chain) ────────────────────────
BLOCKCHAIN_RPC_URL="https://api.avax.network/ext/bc/C/rpc"
DEPLOYER_PRIVATE_KEY=""
VOXPROOF_CONTRACT_ADDRESS=""

# ─── Stripe ─────────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ANNUAL=""       # price_1T7e2gBZS5HFTuixracDpRJ9  (1 an, one-time)
STRIPE_PRICE_LIFETIME=""     # price_1T7rPnBZS5HFTuix6HBExXFs  (à vie, one-time)

# ─── Email (Brevo) ───────────────────────────────────────
BREVO_API_KEY=""
BREVO_SENDER_EMAIL="noreply@voxproof.io"
BREVO_SENDER_NAME="VoxProof"

# ─── Email Ghost (Brevo SMTP) ────────────────────────────
BREVO_SMTP_USER=""                   # user SMTP Brevo (si GHOST_ENABLED)
BREVO_SMTP_PASS=""                   # password SMTP Brevo

# ─── Backend ────────────────────────────────────────────
PORT=4000
NODE_ENV=production
FRONTEND_URL="https://app.client.com"
PROCESSOR_URL="http://processor:5000" # Docker: nom de service interne

# ─── Frontend (Vite) — embarqués dans le build ──────────
# En production: pointer vers api.app.client.com
VITE_API_URL="https://api.app.client.com"
VITE_STRIPE_PUBLISHABLE_KEY=""
VITE_STRIPE_PRICE_ANNUAL=""     # price_1T7e2gBZS5HFTuixracDpRJ9
VITE_STRIPE_PRICE_LIFETIME=""   # price_1T7rPnBZS5HFTuix6HBExXFs
VITE_CONTRACT_ADDRESS=""
VITE_AVALANCHE_CHAIN_ID="43114"
