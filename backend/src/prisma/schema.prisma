generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum KycStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SessionStatus {
  RECORDING    // user is recording the 5 texts
  PROCESSING   // sent to Python processor
  ANCHORED     // hash stored on blockchain
  FAILED       // processing or anchoring failed
}

enum ProductType {
  ANNUAL    // 1 year access
  LIFETIME  // permanent access
}

model User {
  id                     String         @id @default(uuid())
  email                  String         @unique
  passwordHash           String
  firstName              String?
  lastName               String?
  stripeCustomerId       String?
  kycStatus              KycStatus      @default(PENDING)
  kycVerificationId      String?
  kycVerifiedAt          DateTime?
  isAdmin                Boolean        @default(false)
  emailVerified          Boolean        @default(false)
  emailVerificationToken String?
  passwordResetToken     String?
  passwordResetExpiry    DateTime?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  sessions               VoiceSession[]
  purchases              Purchase[]
  activityLogs           ActivityLog[]

  @@map("users")
}

// One purchase = one blockchain certification credit
model Purchase {
  id                    String      @id @default(uuid())
  userId                String
  stripePaymentIntentId String?     @unique
  stripePriceId         String
  productType           ProductType
  usedAt                DateTime?   // null = credit available, set when session is anchored
  validUntil            DateTime?   // null = lifetime

  createdAt             DateTime    @default(now())

  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  session               VoiceSession?

  @@map("purchases")
}

// ─── Text sets ────────────────────────────────────────────────────────────────
// Admin-managed sets of 5 reading texts in 3 languages.
// texts: { fr: string[], en: string[], es: string[] }
model TextSet {
  id        String   @id @default(uuid())
  name      String
  theme     String   @unique
  isActive  Boolean  @default(true)
  isDefault Boolean  @default(false)
  isBuiltin Boolean  @default(false)  // standard sets, read-only
  texts     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("text_sets")
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String   // REGISTER | LOGIN | PURCHASE | SESSION_ANCHORED | PDF_DOWNLOADED | TEXTS_DOWNLOADED
  metadata  Json?    // { email, sessionId, productType, ... }
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("activity_logs")
}

// Global app config (key-value)
model AppConfig {
  key   String @id
  value String

  @@map("app_config")
}

model VoiceSession {
  id             String        @id @default(uuid())
  userId         String
  purchaseId     String?       @unique
  language       String        @default("fr")
  textSetIndex   Int

  status         SessionStatus @default(RECORDING)
  kycVerified    Boolean       @default(false)

  acousticHash   String?       @unique
  voiceHash      String?
  voiceCentroid  Json?             // GE2E d-vector centroid (256 float32) for cosine similarity
  txHash         String?       @unique
  blockNumber    Int?
  anchoredAt     DateTime?

  pdfBase64             String?  @db.Text
  spectrogramBase64     String?  @db.Text
  spectrogramMetrics    Json?
  radarChartBase64      String?  @db.Text
  propertiesChartBase64 String?  @db.Text
  validUntil     DateTime?     // null = lifetime
  emailSentAt    DateTime?
  audioCids      String[]      // IPFS CIDs for 5 audio files (available 5 days)
  audioUnpinAt   DateTime?     // when to unpin from Pinata (anchoredAt + 5 days)

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  purchase       Purchase?     @relation(fields: [purchaseId], references: [id])

  @@map("voice_sessions")
}
