generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum KycStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SubscriptionPlan {
  STARTER
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
}

model User {
  id                    String             @id @default(uuid())
  email                 String             @unique
  passwordHash          String
  walletAddress         String?            @unique
  firstName             String?
  lastName              String?
  kycStatus             KycStatus          @default(PENDING)
  kycVerificationId     String?            // Stripe Identity verification session ID
  kycVerifiedAt         DateTime?
  emailVerified         Boolean            @default(false)
  emailVerificationToken String?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  records               VoiceRecord[]
  subscription          Subscription?

  @@map("users")
}

model VoiceRecord {
  id          String   @id @default(uuid())
  userId      String
  title       String
  description String?
  ipfsCid     String   @unique
  audioHash   String   @unique  // SHA-256 hex of the audio file
  fileSizeBytes Int
  durationSeconds Float?
  mimeType    String   @default("audio/webm")
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  proof       Proof?

  @@map("voice_records")
}

model Proof {
  id              String   @id @default(uuid())
  recordId        String   @unique
  txHash          String   @unique  // Avalanche transaction hash
  contractProofId Int                // On-chain proof ID from the contract
  blockNumber     Int
  chainId         Int      @default(43114)
  network         String   @default("avalanche")
  anchoredAt      DateTime @default(now())
  revoked         Boolean  @default(false)
  revokedAt       DateTime?

  record          VoiceRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)

  @@map("proofs")
}

model Subscription {
  id                   String             @id @default(uuid())
  userId               String             @unique
  stripeCustomerId     String             @unique
  stripeSubscriptionId String?            @unique
  plan                 SubscriptionPlan   @default(STARTER)
  status               SubscriptionStatus @default(TRIALING)
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}
